TELEGRAM_BOT_TOKEN=

OPENROUTER_API_KEY=

# Model must support tool/function calling. Recommended free options:
#   meta-llama/llama-3.3-70b-instruct:free   (best free option for tool calling)
#   qwen/qwen-2.5-72b-instruct:free           (good tool calling, fast)
#   google/gemini-2.0-flash-exp:free          (Google, reliable tool calling)
# Avoid: google/gemma-* free models — they do not reliably call tools.
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Optional: comma-separated fallback models tried in order if the primary fails
# (rate limit, 5xx, model unavailable). OpenRouter handles failover at the API level.
# Example: OPENROUTER_FALLBACK_MODELS=qwen/qwen-2.5-72b-instruct:free,google/gemini-2.0-flash-exp:free
OPENROUTER_FALLBACK_MODELS=

EXA_API_KEY=

# Comma-separated list of Telegram user IDs allowed to interact with the bot.
# Use https://t.me/userinfobot to find your numeric user ID.
# At least one ID is required; messages from any other user are silently ignored.
# Example: ALLOWED_USER_IDS=123456789,987654321
ALLOWED_USER_IDS=

SESSION_TTL_MINUTES=10

SCHEDULER_CRON=0 8 * * *   # 8:00 AM UTC+7

# --- Google Chat unread-messages briefing (optional) ---
# Create a Desktop app OAuth client at https://console.cloud.google.com/apis/credentials
# and enable the Google Chat API. Both ID and SECRET are required to enable the feature;
# leave blank to disable. Use /gchatauth in Telegram to authorize.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Localhost port used for the temporary OAuth callback server during /gchatauth.
# Must match a redirect URI registered on your OAuth client (http://localhost:PORT/oauth2callback).
GCHAT_OAUTH_PORT=4085
